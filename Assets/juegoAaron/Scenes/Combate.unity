--- !u!114 &772849793
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 772849792}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f69d2bc11b754009906e0cbd1e40361, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BancoPreguntasAaron
  preguntas:
  - tipo: Bosque
    enunciado: "\xBFQu\xE9 animal de AWAQ puede verse afectado si se destruye el
      bosque?"
    opcionA: "Los animales que viven ah\xED"
    opcionB: Solo las piedras
    opcionC: Solo el agua
    opcionD: Ninguno
    respuestaCorrecta: 0
    dificultad: 0
  - tipo: Rio
    enunciado: "En AWAQ, \xBFqu\xE9 acci\xF3n ayuda m\xE1s a cuidar un r\xEDo?"
    opcionA: Tirar basura lejos de la orilla
    opcionB: "Botar pl\xE1stico al agua"
    opcionC: "Mantener el r\xEDo limpio"
    opcionD: "Usar m\xE1s jab\xF3n en el r\xEDo"
    respuestaCorrecta: 2
    dificultad: 0
  - tipo: Basura
    enunciado: "En una isla de AWAQ, \xBFqu\xE9 debe hacer un guardi\xE1n con la
      basura?"
    opcionA: Dejarla tirada
    opcionB: Quemarla siempre
    opcionC: Recogerla y clasificarla
    opcionD: anzarla al mar
    respuestaCorrecta: 2
    dificultad: 0
  - tipo: "\xC1rboles"
    enunciado: "\xBFPor qu\xE9 son importantes los \xE1rboles en AWAQ?"
    opcionA: Porque solo decoran
    opcionB: Porque dan sombra y vida
    opcionC: Porque ensucian el suelo
    opcionD: Porque bloquean caminos
    respuestaCorrecta: 1
    dificultad: 0
  - tipo: Agua
    enunciado: "\xBFQu\xE9 recurso de AWAQ no debe desperdiciarse?"
    opcionA: Agua
    opcionB: Basura
    opcionC: Humo
    opcionD: Ruido
    respuestaCorrecta: 0
    dificultad: 0
  - tipo: "H\xE1bitat"
    enunciado: "Si en AWAQ un animal pierde su h\xE1bitat, \xBFqu\xE9 pasa?"
    opcionA: Vive mejor
    opcionB: Puede estar en peligro
    opcionC: Se vuelve planta
    opcionD: No pasa nada
    respuestaCorrecta: 1
    dificultad: 1
  - tipo: "Conservaci\xF3n"
    enunciado: "\xBFQu\xE9 pr\xE1ctica ayuda m\xE1s a conservar la naturaleza en
      AWAQ?"
    opcionA: "Cortar \xE1rboles sin control"
    opcionB: Contaminar menos
    opcionC: "Cazar por diversi\xF3n"
    opcionD: "Secar r\xEDos"
    respuestaCorrecta: 1
    dificultad: 1
  - tipo: Animales
    enunciado: "En AWAQ, \xBFqu\xE9 acci\xF3n protege mejor a los animales?"
    opcionA: Perseguirlos
    opcionB: Perseguirlos
    opcionC: Respetar su espacio
    opcionD: Asustarlos
    respuestaCorrecta: 2
    dificultad: 1
  - tipo: "Contaminaci\xF3n"
    enunciado: "\xBFQu\xE9 ocurre si el agua de una laguna se contamina en AWAQ?"
    opcionA: Mejora el ecosistema
    opcionB: Se benefician todos
    opcionC: Se afectan plantas y animales
    opcionD: Solo cambia el color
    respuestaCorrecta: 2
    dificultad: 1
  - tipo: Guardianes
    enunciado: "\xBFQu\xE9 representa un guardi\xE1n en AWAQ?"
    opcionA: Alguien que destruye recursos
    opcionB: Alguien que protege la vida natural
    opcionC: Alguien que ensucia los caminos
    opcionD: ' Alguien que caza animales'
    respuestaCorrecta: 1
    dificultad: 1
  - tipo: "Reforestaci\xF3n"
    enunciado: "En AWAQ, sembrar \xE1rboles ayuda porque\u2026"
    opcionA: Reduce espacios de vida
    opcionB: "Recupera zonas da\xF1adas"
    opcionC: "Contamina m\xE1s"
    opcionD: "Elimina r\xEDos"
    respuestaCorrecta: 1
    dificultad: 1
  - tipo: Ecosistema
    enunciado: "\xBFQu\xE9 pasar\xEDa en AWAQ si desaparecen muchas plantas de una
      zona?"
    opcionA: El ecosistema se debilita
    opcionB: Todo mejora
    opcionC: "Aparecen m\xE1s r\xEDos"
    opcionD: No cambia nada
    respuestaCorrecta: 0
    dificultad: 2
  - tipo: Biodiversidad
    enunciado: "\xBFPor qu\xE9 es importante cuidar todas las especies en AWAQ?"
    opcionA: "Porque cada una cumple una funci\xF3n"
    opcionB: Porque solo adornan
    opcionC: Porque ocupan espacio
    opcionD: "Porque hacen m\xE1s ruido"
    respuestaCorrecta: 0
    dificultad: 2
  - tipo: Sostenibilidad
    enunciado: "En AWAQ, una decisi\xF3n sostenible ser\xEDa\u2026"
    opcionA: "Usar recursos sin l\xEDmite"
    opcionB: Pensar en el futuro del ecosistema
    opcionC: "Cortar todo para avanzar r\xE1pido"
    opcionD: " Ignorar el da\xF1o ambiental"
    respuestaCorrecta: 1
    dificultad: 0
  - tipo: Conciencia ambiental
    enunciado: "\xBFQu\xE9 ense\xF1a AWAQ principalmente al jugador?"
    opcionA: A destruir enemigos sin pensar
    opcionB: A competir por contaminar
    opcionC: A valorar y proteger la naturaleza
    opcionD: A ignorar el entorno
    respuestaCorrecta: 2
    dificultad: 0
